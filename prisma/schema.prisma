generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id                   String    @id @default(cuid())
  phone                String    @unique
  fullName             String?
  email                String?
  address              String?
  projectType          String?
  projectDetails       String?
  timeline             String?
  budgetRange          String?
  leadTemperature      String?   @default("cold")
  appointmentBooked    Boolean   @default(false)
  appointmentStart     DateTime?
  appointmentEnd       DateTime?
  nextStep             String?
  summary              String?
  shoppingSignal       Boolean   @default(false)
  hotSignal            Boolean   @default(false)
  hoaDelay             Boolean   @default(false)
  insuranceClaim       Boolean   @default(false)
  competitorMentioned  Boolean   @default(false)
  referralAdjacent     Boolean   @default(false)
  escalated            Boolean   @default(false)
  dnc                  Boolean   @default(false)
  objections           String[]  @default([])
  callHistory          Json?
  commandsIssued       Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  calls Call[]
  pets  Pet[]
}

model Call {
  id             String   @id @default(cuid())
  leadId         String
  callId         String?  @unique
  transcript     String?
  duration       Int?
  commandsIssued Json?
  tasksCompleted Json?
  outcome        String?
  createdAt      DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Pet {
  id               String    @id @default(cuid())
  leadId           String
  petName          String?
  breed            String?
  color            String?
  weight           String?
  dateOfBirth      String?
  sex              String?
  spayedNeutered   Boolean   @default(false)
  medicalIssues    String?
  allergies        String?
  vetName          String?
  vetPhone         String?
  rabiesCurrent    Boolean   @default(false)
  rabiesExpiration String?
  behavior         String?
  groomingNotes    String?
  lastGroomed      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  owner Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}
