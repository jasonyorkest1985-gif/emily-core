# Neon PostgreSQL — get connection strings from your Neon dashboard
# Use the pooled connection string for DATABASE_URL (pgbouncer)
# Use the direct connection string for DIRECT_URL (migrations)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/emily-core?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/emily-core?sslmode=require"

# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_FROM_NUMBER="+15550000000"

# SendGrid — https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SENDGRID_FROM_EMAIL="emily@yourdomain.com"

# Brave Search — https://api.search.brave.com/app/keys
BRAVE_SEARCH_API_KEY="BSAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# VAPI — https://dashboard.vapi.ai
VAPI_API_KEY="your_vapi_api_key"
VAPI_ASSISTANT_ID="your_vapi_assistant_id"
